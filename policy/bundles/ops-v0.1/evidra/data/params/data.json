{
  "ops.mass_delete.max_deletes": {
    "by_env": { "default": 5, "production": 3 }
  },
  "k8s.namespaces.restricted": {
    "by_env": { "default": ["kube-system"] }
  },
  "k8s.namespaces.protected": {
    "by_env": { "default": ["prod"] }
  },
  "k8s.dangerous_capabilities.list": {
    "by_env": { "default": ["SYS_ADMIN", "SYS_PTRACE", "NET_RAW"] }
  },
  "terraform.sg_open_world.dangerous_ports": {
    "by_env": { "default": [22, 3389] }
  },
  "argocd.autosync.deny_automated": {
    "by_env": { "default": false, "production": true }
  },
  "argocd.dangerous_sync.deny_combo": {
    "by_env": { "default": false, "production": true }
  },
  "aws_s3.versioning.require": {
    "by_env": { "default": false, "production": true }
  },
  "ops.destructive_operations": {
    "by_env": {
      "default": [
        "kubectl.delete",
        "kubectl.apply",
        "oc.delete",
        "oc.apply",
        "terraform.apply",
        "terraform.destroy",
        "helm.upgrade",
        "helm.uninstall",
        "argocd.sync",
        "argocd.project"
      ]
    }
  },
  "ops.profile": {
    "by_env": {
      "default": "ops",
      "baseline-test": "baseline"
    }
  },
  "ops.context_requirements": {
    "by_env": {
      "default": {
        "kubectl.delete": {
          "hint": "Provide: namespace",
          "skeleton": "{\"namespace\": \"...\", \"resource_count\": 0}"
        },
        "kubectl.apply": {
          "hint": "Provide: namespace + containers[].image (for workload resources)",
          "skeleton": "{\"namespace\": \"...\", \"resource\": \"configmap\"}"
        },
        "oc.delete": {
          "hint": "Provide: namespace",
          "skeleton": "{\"namespace\": \"...\", \"resource_count\": 0}"
        },
        "oc.apply": {
          "hint": "Provide: namespace + containers[].image (for workload resources)",
          "skeleton": "{\"namespace\": \"...\", \"resource\": \"configmap\"}"
        },
        "terraform.apply": {
          "hint": "Provide: at least one of resource_types, security_group_rules, iam_policy_statements, s3_public_access_block",
          "skeleton": "{\"resource_types\": [\"...\"]}"
        },
        "terraform.destroy": {
          "hint": "Provide: destroy_count (number)",
          "skeleton": "{\"destroy_count\": 0}"
        },
        "helm.*": {
          "hint": "Provide: namespace",
          "skeleton": "{\"namespace\": \"...\"}"
        },
        "argocd.sync": {
          "hint": "Provide: app_name or sync_policy",
          "skeleton": "{\"app_name\": \"...\"}"
        }
      }
    }
  }
}
