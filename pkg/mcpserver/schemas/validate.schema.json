{
  "type": "object",
  "required": [
    "actor",
    "tool",
    "operation",
    "params",
    "context"
  ],
  "properties": {
    "actor": {
      "type": "object",
      "description": "Invocation initiator identity.",
      "required": [
        "type",
        "id",
        "origin"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "ci"
          ],
          "description": "Security classification for decision behavior."
        },
        "id": {
          "type": "string",
          "description": "Actor identifier."
        },
        "origin": {
          "type": "string",
          "enum": [
            "mcp",
            "cli",
            "api"
          ],
          "description": "Invocation source (mcp|cli|api)."
        }
      }
    },
    "tool": {
      "type": "string",
      "description": "Execution tool name (kubectl, terraform, helm, argocd, oc). Use the tool that performs the mutation, not the manifest generator. For kustomize, jsonnet, or cdk8s output applied via kubectl, use 'kubectl'.",
      "examples": ["kubectl", "terraform", "helm", "argocd", "oc"]
    },
    "operation": {
      "type": "string",
      "description": "Operation (e.g. plan, apply)."
    },
    "environment": {
      "type": "string",
      "description": "Target environment label for environment-specific policy params (e.g. production, staging). When omitted, server default or 'default' is used."
    },
    "params": {
      "type": "object",
      "description": "Operation parameters; include risk_tags/asserted data.",
      "properties": {
        "payload": {
          "type": "object",
          "description": "Kubernetes payload may be a native manifest (Deployment/Pod/CronJob) or a flat internal shape; Evidra-Lock canonicalizes it before policy evaluation using tool-aware normalization.",
          "examples": [
            {
              "kind": "Deployment",
              "metadata": {
                "namespace": "default"
              },
              "spec": {
                "template": {
                  "spec": {
                    "containers": [
                      {
                        "name": "api",
                        "image": "nginx:1.27.0"
                      }
                    ]
                  }
                }
              }
            },
            {
              "namespace": "default",
              "resource": "deployment",
              "containers": [
                {
                  "name": "api",
                  "image": "nginx:1.27.0"
                }
              ]
            }
          ]
        }
      }
    },
    "context": {
      "type": "object",
      "description": "Optional free-form context metadata.",
      "additionalProperties": true,
      "properties": {
        "source": {
          "type": "string",
          "description": "Optional free-form metadata about request origin context. Not used for security classification."
        }
      }
    }
  }
}
