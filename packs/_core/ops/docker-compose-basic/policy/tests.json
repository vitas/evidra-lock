{
  "pack": "docker-compose-basic",
  "policy": "policy.rego",
  "data": "data.example.json",
  "cases": [
    {
      "name": "compose config allowed",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "docker-compose",
        "operation": "config",
        "params": {"file": "./deploy/compose.yaml"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": true, "risk_level": "low", "reason": "allowed_read_operation"}
    },
    {
      "name": "compose up-service dev allowed",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "docker-compose",
        "operation": "up-service",
        "params": {"file": "./compose/app.yaml", "service": "api"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": true, "risk_level": "high", "reason": "allowed_compose_write_dev"}
    },
    {
      "name": "compose restart-service prod critical",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "docker-compose",
        "operation": "restart-service",
        "params": {"file": "./deploy/compose.yaml", "service": "api"},
        "context": {"environment": "prod"}
      },
      "expect": {"allow": true, "risk_level": "critical", "reason": "allowed_compose_write_prod"}
    },
    {
      "name": "compose file outside allowlist denied",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "docker-compose",
        "operation": "ps",
        "params": {"file": "./random/compose.yaml"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": false, "risk_level": "critical", "reason": "denied_compose_file_not_allowed"}
    }
  ]
}
