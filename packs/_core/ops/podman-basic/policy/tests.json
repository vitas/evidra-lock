{
  "pack": "podman-basic",
  "policy": "policy.rego",
  "data": "data.example.json",
  "cases": [
    {
      "name": "podman images allowed",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "podman",
        "operation": "images",
        "params": {},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": true, "risk_level": "low", "reason": "allowed_read_operation"}
    },
    {
      "name": "podman push dev allowed",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "podman",
        "operation": "push",
        "params": {"image": "registry.example.com/team/app:1.2.3"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": true, "risk_level": "high", "reason": "allowed_push_dev"}
    },
    {
      "name": "podman push denied latest",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "podman",
        "operation": "push",
        "params": {"image": "registry.example.com/team/app:latest"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": false, "risk_level": "critical", "reason": "denied_push_disallowed_tag"}
    },
    {
      "name": "podman push denied unknown registry",
      "input": {
        "actor": {"type": "human", "id": "test", "origin": "unit"},
        "tool": "podman",
        "operation": "push",
        "params": {"image": "docker.io/library/nginx:1.25.0"},
        "context": {"environment": "dev"}
      },
      "expect": {"allow": false, "risk_level": "critical", "reason": "denied_push_disallowed_registry"}
    }
  ]
}
