{
  "_meta": {
    "id": "k8s_native_cronjob_privileged_deny",
    "rules": ["k8s.privileged_container"],
    "priority": "p0"
  },
  "input": {
    "actor": {"type": "agent", "id": "test-agent", "origin": "cli"},
    "tool": "kubectl",
    "operation": "apply",
    "environment": "dev",
    "params": {
      "action": {
        "kind": "kubectl.apply",
        "target": "default",
        "risk_tags": [],
        "payload": {
          "apiVersion": "batch/v1",
          "kind": "CronJob",
          "metadata": {"name": "nightly", "namespace": "default"},
          "spec": {
            "jobTemplate": {
              "spec": {
                "template": {
                  "spec": {
                    "containers": [
                      {
                        "name": "job",
                        "image": "busybox:1.36",
                        "securityContext": {"privileged": true}
                      }
                    ],
                    "restartPolicy": "OnFailure"
                  }
                }
              }
            }
          }
        }
      }
    },
    "context": {}
  },
  "expect": {
    "allow": false,
    "risk_level": "high",
    "rule_ids_contain": ["k8s.privileged_container"],
    "rule_ids_absent": ["ops.insufficient_context"],
    "hints_min_count": 1
  }
}
